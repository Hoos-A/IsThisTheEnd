{
  "name": "AHS Billing Assistant",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "forwardPorts": [8000, 5173],
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
